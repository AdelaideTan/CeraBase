# ----------------------------------------------------
# LINE Bot API (For Bot Notifications)
# ----------------------------------------------------
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_USER_ID=your_line_user_id

# ----------------------------------------------------
# General Settings
# ----------------------------------------------------
STREAMLIT_APP_URL=https://your-streamlit-app.streamlit.app/
